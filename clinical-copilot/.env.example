# Copy to .env and fill in. NEVER commit real secrets (AUDIT A2).

# OpenEMR database (read-only bounded reads)
COPILOT_DB_HOST=127.0.0.1
COPILOT_DB_PORT=8320
COPILOT_DB_USER=openemr
COPILOT_DB_PASSWORD=openemr
COPILOT_DB_NAME=openemr

# LLM provider — set provider=mock to run fully offline (deterministic, free)
COPILOT_LLM_PROVIDER=openai
COPILOT_LLM_API_KEY=
COPILOT_LLM_MODEL_FAST=gpt-4o-mini
COPILOT_LLM_MODEL_SYNTH=gpt-4o

# Observability (optional; degrades to no-op if unset)
COPILOT_LANGFUSE_PUBLIC_KEY=
COPILOT_LANGFUSE_SECRET_KEY=
COPILOT_LANGFUSE_HOST=https://cloud.langfuse.com

COPILOT_ENVIRONMENT=dev
